---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`About — ${SITE_TITLE}`} description="Learn about Visio.ai and our mission to transform visual intelligence." />
	</head>
	<body>
		<Header />
		<main>
			<section class="page-hero">
				<div class="container">
					<p class="section-label animate-in">About us</p>
					<h1 class="animate-in animate-in-delay-1">Building the future of<br />visual intelligence</h1>
					<p class="page-hero-description animate-in animate-in-delay-2">
						Visio.ai was founded on a simple belief: visual data holds answers that traditional analytics miss. We build AI that sees, understands, and helps you act.
					</p>
				</div>
			</section>

			<section class="about-content">
				<div class="container container--narrow">
					<div class="prose animate-in animate-in-delay-3">
						<h2>Our mission</h2>
						<p>
							We empower organisations to unlock the full potential of their visual data. From retail analytics to industrial inspection, our platform transforms raw imagery into decisions that drive real outcomes.
						</p>

						<h2>What we do</h2>
						<p>
							Visio.ai combines state-of-the-art computer vision with intuitive dashboards and seamless integrations. Our platform processes millions of images daily, delivering real-time insights with enterprise-grade reliability.
						</p>
						<p>
							Whether you're monitoring foot traffic, inspecting production lines, or analysing satellite imagery, Visio.ai adapts to your use case and scales with your needs.
						</p>

						<h2>Our approach</h2>
						<p>
							We believe the best AI is invisible — it works quietly in the background, surfacing insights exactly when you need them. That's why we focus relentlessly on accuracy, speed, and ease of use.
						</p>
						<p>
							Every feature we build starts with a question: does this help our customers make better decisions? If the answer isn't a clear yes, we go back to the drawing board.
						</p>
					</div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.page-hero {
		padding: var(--space-4xl) 0 var(--space-3xl);
		text-align: center;
	}

	.page-hero h1 {
		max-width: 640px;
		margin: 0 auto var(--space-lg);
	}

	.page-hero-description {
		font-size: 1.1rem;
		color: var(--color-text-secondary);
		line-height: 1.7;
		max-width: 520px;
		margin: 0 auto;
	}

	.section-label {
		font-family: var(--font-display);
		font-weight: 600;
		font-size: 0.8rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--color-accent);
		margin-bottom: var(--space-sm);
	}

	.about-content {
		padding: 0 0 var(--space-5xl);
	}

	.about-content h2 {
		font-size: 1.5rem;
		margin-top: var(--space-2xl);
	}

	.about-content h2:first-child {
		margin-top: 0;
	}
</style>
