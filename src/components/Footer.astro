---
const today = new Date();
---

<footer>
	<div class="container">
		<div class="footer-grid">
			<div class="footer-brand">
				<a href="/" class="footer-logo">
					<img src="/logo-white.svg" alt="Visio.ai" height="16" />
				</a>
				<p class="footer-tagline">Your AI co-pilot for store operations, helping you scale operational excellence across all locations.</p>
			</div>
			<div class="footer-links">
				<h4>Product</h4>
				<a href="/about">About</a>
				<a href="/blog">Blog</a>
			</div>
			<div class="footer-links">
				<h4>Connect</h4>
				<a href="https://www.linkedin.com/company/visio-ai/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
				<a href="mailto:hello@visio.ai">Email</a>
			</div>
		</div>
		<div class="footer-bottom">
			<p>&copy; {today.getFullYear()} Visio.ai. All rights reserved.</p>
		</div>
	</div>
</footer>

<style>
	footer {
		background: var(--color-neutral-900);
		color: var(--color-neutral-400);
		padding: var(--space-4xl) 0 var(--space-xl);
	}

	.footer-grid {
		display: grid;
		grid-template-columns: 2fr 1fr 1fr;
		gap: var(--space-3xl);
	}

	.footer-brand {
		max-width: 340px;
	}

	.footer-logo {
		display: inline-flex;
		align-items: center;
		text-decoration: none;
		margin-bottom: var(--space-md);
	}

	.footer-logo img {
		border-radius: 0;
		height: 30px;
		width: auto;
	}

	.footer-tagline {
		font-size: 0.9rem;
		line-height: 1.6;
		margin: 0;
	}

	.footer-links h4 {
		font-family: var(--font-body);
		font-size: 0.8rem;
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--color-neutral-300);
		margin-bottom: var(--space-md);
	}

	.footer-links a {
		display: block;
		color: var(--color-neutral-400);
		font-size: 0.9rem;
		padding: 0.3em 0;
		transition: color var(--transition-fast);
	}

	.footer-links a:hover {
		color: var(--white);
	}

	.footer-bottom {
		margin-top: var(--space-3xl);
		padding-top: var(--space-xl);
		border-top: 1px solid var(--color-neutral-800);
	}

	.footer-bottom p {
		font-size: 0.8rem;
		margin: 0;
	}

	@media (max-width: 768px) {
		footer {
			padding: var(--space-3xl) 0 var(--space-lg);
		}

		.footer-grid {
			grid-template-columns: 1fr;
			gap: var(--space-xl);
		}
	}
</style>
